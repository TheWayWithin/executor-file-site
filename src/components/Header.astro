---
const nav = [
  { href: '/how-it-works', label: 'How it works' },
  { href: '/get-started', label: 'Get started' },
  { href: '/recover', label: 'For executors' },
  { href: '/why-trust-this', label: 'Why trust this' },
  { href: '/story', label: 'Story' },
  { href: '/learn', label: 'Learn' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href="/">Executor File</a>
    <nav aria-label="Main">
      <ul>
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={path === item.href || path.startsWith(item.href + '/') ? 'page' : undefined}
            >{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
  }
  .bar {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-3) var(--space-5);
    padding-block: var(--space-3);
  }
  .brand {
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-decoration: none;
    font-size: var(--text-lg);
  }
  nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    padding: 0;
    margin: 0;
  }
  nav li { margin: 0; }
  nav a {
    color: var(--ink-soft);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
  }
  nav a:hover { color: var(--accent-strong); }
  nav a[aria-current='page'] {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.4em;
  }
</style>
