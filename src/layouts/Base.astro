---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_NAME, SITE_URL, PLAUSIBLE_DOMAIN } from '../config';

interface Props {
  title: string;
  description: string;
  /**
   * Recovery pages set this: no analytics of any kind, no marketing chrome.
   * This is the layout-level exclusion required by the site policy; the
   * Plausible snippet is simply never rendered when it is true.
   */
  quiet?: boolean;
}

const { title, description, quiet = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE_URL).href;
const ogImage = new URL('/og/default.png', SITE_URL).href;
---
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title === SITE_NAME ? title : `${title} · ${SITE_NAME}`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_NAME}: Learn`} href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    {!quiet && (
      <script defer data-domain={PLAUSIBLE_DOMAIN} src="https://plausible.io/js/script.js"></script>
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    {!quiet && <Header />}
    <main id="main">
      <slot />
    </main>
    {!quiet && <Footer />}
  </body>
</html>
