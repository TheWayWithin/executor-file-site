---
// Layout for /recover pages. Strictest rules on the site: no analytics, no
// affiliate links, no marketing, no nav clutter. Big type, high contrast,
// and a print stylesheet, because the likely reader is stressed, possibly
// older, and may be printing.
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
---
<Base title={title} description={description} quiet>
  <div class="recover wrap">
    <header class="recover-top" role="banner">
      <a href="/">Executor File</a>
    </header>
    <slot />
    <footer class="recover-end">
      <p>
        This page mirrors the printed guide exactly and stays at this address
        permanently. It is free to use and asks nothing of you.
      </p>
    </footer>
  </div>
</Base>

<style is:global>
  .recover {
    max-width: 46rem;
    font-size: 1.3125rem;
    line-height: 1.65;
    padding-block: var(--space-4) var(--space-6);
  }
  .recover h1 { font-size: 2rem; margin-bottom: var(--space-4); }
  .recover h2 { font-size: 1.625rem; }
  .recover pre {
    font-size: 1.125rem;
    border-width: 2px;
  }
  .recover code { font-size: 0.92em; }
  .recover-top {
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--rule);
    font-size: 1rem;
  }
  .recover-top a {
    color: var(--ink-soft);
    text-decoration: none;
    font-weight: 600;
  }
  .recover-end {
    margin-top: var(--space-6);
    padding-top: var(--space-3);
    border-top: 1px solid var(--rule);
    color: var(--ink-soft);
    font-size: 1rem;
  }

  @media print {
    @page { margin: 10mm 14mm; }
    .recover {
      font-size: 9.5pt;
      line-height: 1.38;
      max-width: none;
      padding: 0;
    }
    .recover h1 { font-size: 14pt; margin-bottom: 8pt; }
    .recover h2 { font-size: 11.5pt; margin-top: 8pt; margin-bottom: 4pt; }
    .recover p, .recover ul, .recover ol, .recover table, .recover pre { margin-bottom: 4pt; }
    .recover li { margin-bottom: 1pt; }
    .recover th, .recover td { padding: 2pt 6pt; }
    .recover table { font-size: 9.5pt; }
    .recover pre {
      font-size: 9pt;
      border: 1pt solid #999;
      background: none;
      padding: 4pt 6pt;
      page-break-inside: avoid;
    }
    .recover code { background: none; }
    .recover a { color: inherit; text-decoration: none; }
    .recover-top, .recover-end, .no-print { display: none; }
    .recover li, .recover tr { page-break-inside: avoid; }
  }
</style>
